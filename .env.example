# ─── Database (Neon PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host.neon.tech/vaarsamen?sslmode=require

# ─── NextAuth / Auth.js ──────────────────────────────────────────────────────
AUTH_SECRET=<genereer met: openssl rand -base64 32>
NEXTAUTH_URL=https://jouwapp.vercel.app

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Resend (e-mail magic link) ──────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@vaarsamen.nl

# ─── Pusher (realtime berichten) ─────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_SECRET=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=eu

# ─── Vercel Blob (foto uploads) ──────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ─── Stripe (premium abonnementen) ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Web Push notificaties ───────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:info@vaarsamen.nl
